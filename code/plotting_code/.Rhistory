?TESSERA::prep_synth_data
setwd("~/Dropbox/research/spatial/code/plotting_code")
knitr::opts_chunk$set(echo = FALSE,
warning = FALSE,
message = FALSE)
# Library
library(openxlsx)
library(dplyr)
library(forcats)
library(ggplot2)
library(patchwork)
library(TESSERA)
# Paths
processed_data_path <- "../../data/processed/"
raw_data_path <- "../../data/raw/"
figure_path <- "../../figures/real/DE_marker_genes/"
# Model type
glm_pattern_type <- "GLM"
pattern_type <- "Leroux"
# Read in kidney data
seu_kid <- readRDS(paste0(processed_data_path, "seu_kidney.rds"))
seu_kid <- seu_kid[1:3000, ]
# Read in pseudobulk results
limma_df_all <- readRDS(paste0(processed_data_path, "limma_voom_real_markergene_natgen_kidney.rds"))
deseq2_df_all <- readRDS(paste0(processed_data_path, "DESeq2_real_markergene_natgen_kidney.rds"))
# Rename models
limma_df_all <- limma_df_all %>%
mutate(fit_model = recode(fit_model,
"limma_voom" = "limma-voom"))
# Read in GLM model results
glm_wald_df_all <- readRDS(paste0(processed_data_path, "glm_gam_model_results_waldstats_markergene_onlyinteract.rds"))
# Handle missing columns
glm_wald_df_all$contrast_description <- glm_wald_df_all$contrast_name
if (!("fit_model" %in% colnames(glm_wald_df_all))) {
glm_wald_df_all$fit_model <- glm_wald_df_all$model
}
# Rename models
glm_wald_df_all <- glm_wald_df_all %>%
mutate(fit_model = recode(fit_model,
"Poisson_GLM" = "Poisson GLM",
"NB_GLM" = "NB GLM",
"GAM" = "GAM"))
# Add in p-values and adjusted p-values
glm_wald_df_all$wald_pval <- pchisq(glm_wald_df_all$wald_stat_t^2, df = 1, lower.tail = FALSE)
glm_wald_df_all$wald_pval_adj <- NA
for (fm in unique(glm_wald_df_all$fit_model)) {
for (cd in unique(glm_wald_df_all$contrast_description)) {
row_idx <- which((glm_wald_df_all$fit_model == fm) & (glm_wald_df_all$contrast_description == cd))
glm_wald_df_all$wald_pval_adj[row_idx] <- p.adjust(glm_wald_df_all$wald_pval[row_idx], method = "BH")
}
}
# Read in TESSERA results from fitting all genes and contrasts FOR WITHIN CELL TYPE
# Just to get parameters
wald_df_all <- readRDS(paste0(processed_data_path, "real_hyptest_tessera_between_celltypes.rds"))
wald_df_all <- wald_df_all$wald_df_all
# Drop old, redundant columns
#wald_df_all <- select(wald_df_all, -c("wald_scaling", "wald_shift"))
# Rename models
wald_df_all <- wald_df_all %>%
mutate(fit_model = recode(fit_model,
"Leroux" = "TESSERA-Leroux"))
head(limma_df_all)
head(deseq2_df_all)
summary(deseq2_df_all$padj - deseq2_df_all$pval_adj)
# Adjust p-values per contrast to match
for (cd in unique(limma_df_all$contrast_description)) {
row_idx <- which(limma_df_all$contrast_description == cd)
limma_df_all$pval_adj[row_idx] <- p.adjust(limma_df_all$P.Value[row_idx], method = "BH")
}
for (cd in unique(deseq2_df_all$contrast_description)) {
row_idx <- which(deseq2_df_all$contrast_description == cd)
deseq2_df_all$pval_adj[row_idx] <- p.adjust(deseq2_df_all$pvalue[row_idx], method = "BH")
}
head(deseq2_df_all)
head(limma_df_all)
knitr::opts_chunk$set(echo = FALSE,
warning = FALSE,
message = FALSE)
# Library
library(openxlsx)
library(dplyr)
library(forcats)
library(ggplot2)
library(patchwork)
library(TESSERA)
# Paths
processed_data_path <- "../../data/processed/"
raw_data_path <- "../../data/raw/"
figure_path <- "../../figures/real/DE_marker_genes/"
# Model type
glm_pattern_type <- "GLM"
pattern_type <- "Leroux"
# Read in kidney data
seu_kid <- readRDS(paste0(processed_data_path, "seu_kidney.rds"))
seu_kid <- seu_kid[1:3000, ]
# Read in pseudobulk results
limma_df_all <- readRDS(paste0(processed_data_path, "limma_voom_real_markergene_natgen_kidney.rds"))
deseq2_df_all <- readRDS(paste0(processed_data_path, "DESeq2_real_markergene_natgen_kidney.rds"))
# Rename models
limma_df_all <- limma_df_all %>%
mutate(fit_model = recode(fit_model,
"limma_voom" = "limma-voom"))
# Read in GLM model results
glm_wald_df_all <- readRDS(paste0(processed_data_path, "glm_gam_model_results_waldstats_markergene_onlyinteract.rds"))
# Handle missing columns
glm_wald_df_all$contrast_description <- glm_wald_df_all$contrast_name
if (!("fit_model" %in% colnames(glm_wald_df_all))) {
glm_wald_df_all$fit_model <- glm_wald_df_all$model
}
# Rename models
glm_wald_df_all <- glm_wald_df_all %>%
mutate(fit_model = recode(fit_model,
"Poisson_GLM" = "Poisson GLM",
"NB_GLM" = "NB GLM",
"GAM" = "GAM"))
# Add in p-values and adjusted p-values
glm_wald_df_all$wald_pval <- pchisq(glm_wald_df_all$wald_stat_t^2, df = 1, lower.tail = FALSE)
glm_wald_df_all$wald_pval_adj <- NA
for (fm in unique(glm_wald_df_all$fit_model)) {
for (cd in unique(glm_wald_df_all$contrast_description)) {
row_idx <- which((glm_wald_df_all$fit_model == fm) & (glm_wald_df_all$contrast_description == cd))
glm_wald_df_all$wald_pval_adj[row_idx] <- p.adjust(glm_wald_df_all$wald_pval[row_idx], method = "BH")
}
}
# Read in TESSERA results from fitting all genes and contrasts FOR WITHIN CELL TYPE
# Just to get parameters
wald_df_all <- readRDS(paste0(processed_data_path, "real_hyptest_tessera_between_celltypes.rds"))
wald_df_all <- wald_df_all$wald_df_all
# Drop old, redundant columns
#wald_df_all <- select(wald_df_all, -c("wald_scaling", "wald_shift"))
# Rename models
wald_df_all <- wald_df_all %>%
mutate(fit_model = recode(fit_model,
"Leroux" = "TESSERA-Leroux"))
head(limma_df_all)
# Adjust p-values per contrast to match TESSERA/GLMs/GAM
# Limma
for (cd in unique(limma_df_all$contrast_description)) {
row_idx <- which(limma_df_all$contrast_description == cd)
limma_df_all$pval_adj[row_idx] <- p.adjust(limma_df_all$P.Value[row_idx], method = "BH")
}
# DESeq2
for (cd in unique(deseq2_df_all$contrast_description)) {
row_idx <- which(deseq2_df_all$contrast_description == cd)
deseq2_df_all$pval_adj[row_idx] <- p.adjust(deseq2_df_all$pvalue[row_idx], method = "BH")
}
head(limma_df_all)
knitr::opts_chunk$set(echo = FALSE,
warning = FALSE,
message = FALSE)
# Library
library(dplyr)
library(forcats)
library(purrr)
library(ggplot2)
library(patchwork)
# Paths
processed_data_path <- "../../data/processed/"
raw_data_path <- "../../data/raw/"
figure_path <- "../../figures/real/DE_between_conditions_within_celltype/"
# Model type
glm_pattern_type <- "GLM"
pattern_type <- "Leroux"
# Read in kidney data
seu_kid <- readRDS(paste0(processed_data_path, "seu_kidney.rds"))
seu_kid@meta.data$sample <- seu_kid@meta.data$orig.ident
# Read in pseudobulk results
limma_df_all <-  readRDS(paste0(processed_data_path, "limma_voom_real_natgen_kidney.rds"))
deseq2_df_all <-  readRDS(paste0(processed_data_path, "DESeq2_real_natgen_kidney.rds"))
# Read in GLM model results
glm_wald_df_all <- readRDS(paste0(processed_data_path, "glm_gam_model_results_waldstats_onlyinteract.rds"))
glm_summary_out_all <- readRDS(paste0(processed_data_path, "glm_gam_model_results_perfsummary_onlyinteract.rds"))
wald_df_all <- readRDS(paste0(processed_data_path, "real_hyptest_tessera.rds"))
wald_thresh_df <- wald_df_all$fit_results_df
wald_pval_qq_df <- wald_df_all$pval_qq_df
wald_df_all <- wald_df_all$wald_df_all
summary_out_all <- readRDS(paste0(processed_data_path, "real_results_perfsummary_", pattern_type, "_onlyinteract.rds"))
# Add in diagnosis information
summary_out_all <- dplyr::left_join(summary_out_all, dplyr::distinct(seu_kid@meta.data[, c("sample", "Group")]), by = "sample")
summary_out_all$Group <- factor(summary_out_all$Group, levels = c("Control", "HKD", "DKD"))
summary_out_all$sample <- forcats::fct_reorder(summary_out_all$sample, as.numeric(summary_out_all$Group))
# Rename models
limma_df_all <- limma_df_all %>%
mutate(fit_model = recode(fit_model,
"limma_voom" = "limma-voom"))
wald_df_all <- wald_df_all %>%
mutate(fit_model = recode(fit_model,
"Leroux" = "TESSERA-Leroux"))
glm_wald_df_all <- glm_wald_df_all %>%
mutate(fit_model = recode(fit_model,
"NB_GLM" = "NB GLM",
"Poisson_GLM" = "Poisson GLM"))
summary_out_all <- summary_out_all %>%
mutate(fit_model = recode(fit_model,
"Leroux" = "TESSERA-Leroux"))
glm_summary_out_all <- glm_summary_out_all %>%
mutate(fit_model = recode(fit_model,
"Leroux" = "TESSERA-Leroux"))
head(limma_df_all)
# Adjust p-values per contrast to match TESSERA/GLMs/GAM
# Limma
for (cd in unique(limma_df_all$contrast_description)) {
row_idx <- which(limma_df_all$contrast_description == cd)
limma_df_all$pval_adj[row_idx] <- p.adjust(limma_df_all$P.Value[row_idx], method = "BH")
}
# DESeq2
for (cd in unique(deseq2_df_all$contrast_description)) {
row_idx <- which(deseq2_df_all$contrast_description == cd)
deseq2_df_all$pval_adj[row_idx] <- p.adjust(deseq2_df_all$pvalue[row_idx], method = "BH")
}
head(limma_df_all)
head(deseq2$df_all)
head(deseq2_df_all)
