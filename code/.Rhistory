old_df_clean <- old_df %>%
mutate(across(where(is.factor), as.character))
new_df_clean <- new_df %>%
mutate(across(where(is.factor), as.character))
old_common <- old_df_clean %>%
inner_join(new_df_clean[, keys], by = keys) %>%
arrange(across(all_of(keys)))
new_common <- new_df_clean %>%
inner_join(old_df_clean[, keys], by = keys) %>%
arrange(across(all_of(keys)))
# This joins the rows on your keys and puts 'old' and 'new' values side-by-side
diff_table <- inner_join(old_df_clean, new_df_clean, by = keys, suffix = c("_old", "_new"))
# 1. Identify which columns are "results" (the ones that aren't keys)
val_cols <- setdiff(names(old_df_clean), keys)
# 2. Identify rows that have a "real" difference
# We check each result column one by one.
# We use 'near' for numbers to ignore microscopic rounding errors.
is_different <- rep(FALSE, nrow(diff_table))
for (col in val_cols) {
old_val <- diff_table[[paste0(col, "_old")]]
new_val <- diff_table[[paste0(col, "_new")]]
if (is.numeric(old_val)) {
# TRUE if the difference is larger than 1e-10
# The 'abs(...) > 1e-10' handles NAs safely inside the check
diff_found <- abs(old_val - new_val) > 1e-5
} else {
# TRUE if strings/factors don't match exactly
diff_found <- old_val != new_val
}
# Handle NA values: if one is NA and the other isn't, that's a difference
diff_found[is.na(old_val) != is.na(new_val)] <- TRUE
# If both are NA, that's NOT a difference
diff_found[is.na(old_val) & is.na(new_val)] <- FALSE
# Accumulate the differences
is_different <- is_different | (diff_found & !is.na(diff_found))
}
# 3. Create the interleaved column order (e.g., Key1, Key2, ValA_old, ValA_new...)
# This little trick braids the column names together
side_by_side_names <- c(keys)
for (col in val_cols) {
side_by_side_names <- c(side_by_side_names, paste0(col, "_old"), paste0(col, "_new"))
}
# 4. Filter the table to only show the problematic rows
diff_summary <- diff_table[is_different, side_by_side_names]
# 5. Output results
if (nrow(diff_summary) == 0) {
message("✨ Success! No meaningful differences found (all rows match within 1e-10).")
} else {
message("⚠️ Found ", nrow(diff_summary), " rows with actual differences.")
# This will open a window in RStudio to inspect the side-by-side values
View(diff_summary)
}
