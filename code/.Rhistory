table(diff_table[which(abs(diff_table$wald_pval_old - diff_table$wald_pval_new) > 1e-3), ]$baseline_contrast)
table(diff_table[which(abs(diff_table$wald_pval_old - diff_table$wald_pval_new) > 1e-3), ]$true_contrast_value)
table(diff_table[which(abs(diff_table$wald_pval_old - diff_table$wald_pval_new) > 1e-3), ]$baseline_coef_value)
table(diff_table[which(abs(diff_table$wald_pval_old - diff_table$wald_pval_new) > 1e-3), ]$changed_coef_value)
table(diff_table[which(abs(diff_table$wald_pval_old - diff_table$wald_pval_new) > 1e-3), ]$gene)
table(diff_table[which(abs(diff_table$wald_pval_old - diff_table$wald_pval_new) > 1e-3), ]$fit_model)
table(diff_table[which(abs(diff_table$wald_pval_old - diff_table$wald_pval_new) > 1e-3), ]$kernel_type)
table(diff_table[which(abs(diff_table$wald_pval_old - diff_table$wald_pval_new) > 1e-3), ]$contrast_indices)
diff_table[which(abs(diff_table$wald_pval_old - diff_table$wald_pval_new) > 1e-3), ]
View(diff_table[which(abs(diff_table$wald_pval_old - diff_table$wald_pval_new) > 1e-3), ])
summary(diff_table$baseline_coef_value - diff_table$estimated_baseline_coef_new)
summary(diff_table$baseline_coef_value - diff_table$estimated_baseline_coef_old)
summary(diff_table$changed_coef_value - diff_table$estimated_changed_coef_old)
summary(diff_table$changed_coef_value - diff_table$estimated_changed_coef_new)
plot(diff_table$estimated_baseline_coef_new, diff_table$estimated_baseline_coef_old)
plot(diff_table$estimated_changed_coef_old, diff_table$estimated_changed_coef_new)
plot(diff_table$estimated_baseline_coef_old, diff_table$estimated_baseline_coef_new)
